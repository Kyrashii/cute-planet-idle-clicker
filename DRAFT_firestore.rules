rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Schema Validation Helper for Game Save entity
    function isValidSave(data) {
      return data.userId is string &&
             data.userId == request.auth.uid;
    }

    // Match rules for user saves collection
    match /saves/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) &&
                       isValidId(userId) &&
                       isValidSave(request.resource.data);

      allow update: if isOwner(userId) &&
                       isValidId(userId) &&
                       isValidSave(request.resource.data);

      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
